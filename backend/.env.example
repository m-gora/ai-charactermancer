# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=charactermancer

# Auth0 — must match the frontend VITE_AUTH0_* values
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier.example.com

# Optional — override the default uvicorn bind address / port
# HOST=0.0.0.0
# PORT=8000
