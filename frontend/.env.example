# ── Auth0 ──────────────────────────────────────────────────────────────────────
# Your Auth0 tenant domain, e.g. my-app.eu.auth0.com
VITE_AUTH0_DOMAIN=

# The Client ID of your Auth0 Single-Page Application
VITE_AUTH0_CLIENT_ID=

# The API Audience identifier configured in your Auth0 API settings
# Must match AUTH0_AUDIENCE in the backend .env
VITE_AUTH0_AUDIENCE=

# ── Backend proxy ──────────────────────────────────────────────────────────────
# Only needed if the backend runs on a non-default port (default: http://localhost:8000)
# BACKEND_URL=http://localhost:8000
